{
  "name": "focus-track-desktop-app",
  "version": "1.0.0",
  "private": true,
  "description": "Electron + React desktop app for FocusTrack",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "npm run build:electron && wait-on tcp:4587 && cross-env VITE_DEV_SERVER_URL=http://localhost:4587 electron .",
    "build": "npm-run-all typecheck build:renderer build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/write-electron-package.cjs",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.codinghelp.focustrack",
    "productName": "FocusTrack",
    "copyright": "Copyright (c) 2026 CodingHelp",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": "dist-electron/electron/main.js",
      "type": "commonjs"
    },
    "files": [
      "build/**/*",
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FocusTrack"
    }
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.1.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wait-on": "^8.0.3"
  }
}
